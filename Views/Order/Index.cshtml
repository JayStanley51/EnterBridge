@model List<EnterBridgePOC.Models.Api.ProductDto>

@{
    ViewData["Title"] = "New Order";
    int groupIndex = 0;
}

@section Scripts {
<script>
    const STORAGE_KEY = 'order-open-sections';

    // Restore open sections saved before the last Add to Order submit
    const saved = JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '[]');
    if (saved.length) {
        saved.forEach(id => {
            const el = document.getElementById(id);
            if (el) new bootstrap.Collapse(el, { show: true });
        });
        sessionStorage.removeItem(STORAGE_KEY);
    }

    // Track chevron state
    document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(btn => {
        const target = document.querySelector(btn.dataset.bsTarget);
        if (!target) return;
        target.addEventListener('show.bs.collapse', () => btn.querySelector('.chevron').textContent = '▲');
        target.addEventListener('hide.bs.collapse', () => btn.querySelector('.chevron').textContent = '▼');
    });

    // Before Add to Order submits, save which category collapses are open
    document.querySelectorAll('form[action*="AddItem"]').forEach(form => {
        form.addEventListener('submit', () => {
            const open = [...document.querySelectorAll('.category-section .collapse.show')]
                .map(el => el.id)
                .filter(Boolean);
            sessionStorage.setItem(STORAGE_KEY, JSON.stringify(open));
        });
    });

    document.getElementById('skuSearch').addEventListener('input', function () {
        const term = this.value.trim().toLowerCase();
        document.querySelectorAll('.category-section').forEach(section => {
            let anyVisible = false;
            section.querySelectorAll('tbody tr').forEach(row => {
                const sku = row.querySelector('.sku-cell')?.textContent.trim().toLowerCase() ?? '';
                const match = !term || sku.includes(term);
                row.style.display = match ? '' : 'none';
                if (match) anyVisible = true;
            });
            section.style.display = anyVisible || !term ? '' : 'none';
            if (term && anyVisible) {
                const collapse = section.querySelector('.collapse');
                if (collapse && !collapse.classList.contains('show'))
                    new bootstrap.Collapse(collapse, { show: true });
            }
        });
    });
</script>
}

<div class="mb-3">
    <input id="skuSearch" type="search" class="form-control" placeholder="Search by SKU..." />
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>New Order</h2>
    <div class="d-flex gap-2 align-items-center">
        @if ((int)(ViewData["OrderCount"] ?? 0) > 0)
        {
            <span class="badge bg-primary fs-6">@ViewData["OrderCount"] item(s) in order</span>
            <form method="post" asp-action="PlaceOrder" asp-controller="Order" class="d-inline">
                <button type="submit" class="btn btn-success">Place Order</button>
            </form>
        }
        <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline-secondary">← Back</a>
    </div>
</div>

@if (Model == null || Model.Count == 0)
{
    <p class="text-muted">No products available.</p>
}
else
{
    @foreach (var group in Model.GroupBy(p => p.Category).OrderBy(g => g.Key.ToString()))
    {
        var collapseId = $"category-{groupIndex++}";
        <div class="mt-3 category-section">
            <button class="btn btn-light w-100 text-start d-flex justify-content-between align-items-center border"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#@collapseId"
                    aria-expanded="false">
                <span class="fw-semibold">@group.Key <span class="text-muted fw-normal fs-6">(@group.Count())</span></span>
                <span class="chevron">▼</span>
            </button>
            <div class="collapse" id="@collapseId">
                <div class="table-responsive mb-2">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>SKU</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in group)
                            {
                                <tr>
                                    <td>@product.Name</td>
                                    <td><code class="sku-cell">@product.Sku</code></td>
                                    <td class="text-end">
                                        <form method="post" asp-action="AddItem" asp-controller="Order">
                                            <input type="hidden" name="productId" value="@product.Id" />
                                            <input type="hidden" name="name" value="@product.Name" />
                                            <input type="hidden" name="sku" value="@product.Sku" />
                                            <button type="submit" class="btn btn-sm btn-primary">+ Add to Order</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
