@model EnterBridgePOC.Models.Order

@{
    var collapseId = ViewData["CollapseId"]?.ToString() ?? "order-0";
    bool isForeman = ViewData["IsForeman"] is true;
}

<div class="mt-2">
    <div class="d-flex align-items-center border rounded overflow-hidden">
        <button class="btn btn-light flex-grow-1 text-start d-flex align-items-center gap-2 border-0 rounded-0"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#@collapseId"
                aria-expanded="false">
            <span class="fw-semibold">Order #@Model.Id</span>
            <span class="text-muted">@Model.PlacedAt.ToString("yyyy-MM-dd")</span>
            @if (isForeman)
            {
                <span class="text-muted fw-normal">Placed by: <strong>@Model.Role</strong></span>
            }
            <span class="text-muted fw-normal fs-6">@Model.Items.Sum(i => i.Quantity) item(s)</span>
            @{
                var (badgeClass, badgeLabel) = Model.Status switch
                {
                    EnterBridgePOC.Models.ApprovalStatus.Approved => ("bg-success", "Approved"),
                    EnterBridgePOC.Models.ApprovalStatus.Rejected => ("bg-danger", "Rejected"),
                    _ => ("bg-warning text-dark", "Pending")
                };
            }
            <span class="badge @badgeClass">@badgeLabel</span>
            <span class="chevron ms-auto">▼</span>
        </button>
        @if (isForeman && Model.Status == EnterBridgePOC.Models.ApprovalStatus.Pending)
        {
            <a asp-action="EditOrder" asp-controller="Order" asp-route-orderId="@Model.Id"
               class="btn btn-warning btn-sm rounded-0 h-100 px-3 border-start">✎ Edit</a>
            <form method="post" asp-action="Approve" asp-controller="Order" class="d-inline border-start">
                <input type="hidden" name="orderId" value="@Model.Id" />
                <button type="submit" class="btn btn-success btn-sm rounded-0 h-100 px-3">✓ Approve</button>
            </form>
            <form method="post" asp-action="Reject" asp-controller="Order" class="d-inline border-start">
                <input type="hidden" name="orderId" value="@Model.Id" />
                <button type="submit" class="btn btn-danger btn-sm rounded-0 h-100 px-3">✗ Reject</button>
            </form>
        }
        @if (!isForeman)
        {
            <form method="post" asp-action="Reorder" asp-controller="Order" class="d-inline border-start">
                <input type="hidden" name="orderId" value="@Model.Id" />
                <button type="submit" class="btn btn-primary btn-sm rounded-0 h-100 px-3">↺ Reorder</button>
            </form>
        }
    </div>
    <div class="collapse" id="@collapseId">
        <div class="table-responsive mb-2">
            <table class="table table-sm table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>SKU</th>
                        <th>Qty</th>
                        <th>Price at Order</th>
                        <th>Line Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td><code>@item.Sku</code></td>
                            <td>@item.Quantity</td>
                            <td>@item.PriceAtOrder.ToString("C") / @item.UnitOfMeasure</td>
                            <td>@((item.PriceAtOrder * item.Quantity).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
